# ============================================
# Doctor Booking App - Environment Template
# ============================================
# Copy file này thành .env.dev / .env.staging / .env.prod
# và điền giá trị thật cho từng môi trường.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Agora (Video Call)
AGORA_APP_ID=
AGORA_CERTIFICATE=

# PayOS (Payment)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Firebase (Web Push Notifications)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Feature Flags
ENABLE_LOGGING=false
ENABLE_CRASHLYTICS=false
